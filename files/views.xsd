                <xs:attribute type="xs:string" name="style" use="optional"/>
                <xs:attribute type="xs:string" name="position" use="optional"/>
                <xs:attribute type="xs:string" name="title" use="optional"/>
            </xs:extension>
        </xs:simpleContent>
    </xs:complexType>
