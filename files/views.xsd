        </xs:sequence>
        <xs:attribute type="xs:string" name="criteria"/>
        <xs:attribute type="xs:string" name="on-init" use="optional"/>
    </xs:complexType>
    <xs:complexType name="buttonType">
        <xs:simpleContent>
            <xs:extension base="xs:string">
                <xs:attribute type="xs:string" name="type" use="optional"/>
