            <xs:element type="fieldType" name="field" maxOccurs="unbounded" minOccurs="0"/>
            <xs:element type="gridType" name="grid" minOccurs="0"/>
            <xs:any minOccurs="0"/>
        </xs:sequence>
        <xs:attribute type="xs:string" name="label" use="optional"/>
        <xs:attribute type="xs:string" name="collapsable" use="optional"/>
        <xs:attribute type="xs:string" name="cols" use="optional"/>
        <xs:attribute type="xs:string" name="colspan" use="optional"/>
        <xs:attribute type="xs:string" name="name" use="optional"/>
        <xs:attribute type="xs:string" name="style" use="optional"/>
        <xs:attribute type="xs:string" name="t-readonly" use="optional"/>
        <xs:attribute type="xs:string" name="t-visible" use="optional"/>
        <xs:attribute type="xs:string" name="t-reset" use="optional"/>
        <xs:attribute type="xs:string" name="editor" use="optional"/>
        <xs:attribute type="xs:string" name="criteria" use="optional"/>
        <xs:attribute type="xs:string" name="default" use="optional"/>
        <xs:attribute type="xs:string" name="required" use="optional"/>
        <xs:attribute type="xs:string" name="length" use="optional"/>
        <xs:attribute type="xs:string" name="trim" use="optional"/>
        <xs:attribute type="xs:string" name="class" use="optional"/>
        <xs:attribute type="xs:string" name="lookup" use="optional"/>
        <xs:attribute type="xs:string" name="onchange" use="optional"/>
        <xs:attribute type="xs:string" name="nolabel" use="optional"/>
        <xs:attribute type="xs:string" name="width" use="optional"/>
        <xs:attribute type="xs:string" name="rowspan" use="optional"/>
        <xs:attribute type="xs:string" name="min" use="optional"/>
        <xs:attribute type="xs:string" name="max" use="optional"/>
        <xs:attribute type="xs:string" name="step" use="optional"/>
        <xs:attribute type="xs:string" name="defaultValue" use="optional"/>
        <xs:attribute type="xs:string" name="rows" use="optional"/>
        <xs:attribute type="xs:string" name="placeholder" use="optional"/>
        <xs:attribute type="xs:string" name="readonly" use="optional"/>
    </xs:complexType>
    <xs:complexType name="tabsType">
