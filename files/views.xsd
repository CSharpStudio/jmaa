        <xs:attribute type="xs:string" name="inline" use="optional"/>
        <xs:attribute type="xs:string" name="dialog" use="optional"/>
        <xs:attribute type="xs:string" name="on-init" use="optional"/>
        <xs:attribute type="xs:string" name="on-load" use="optional"/>
        <xs:attribute type="xs:string" name="on-create" use="optional"/>
        <xs:attribute type="xs:string" name="on-save" use="optional"/>
        <xs:attribute type="xs:string" name="on-edit-load" use="optional"/>
        <xs:attribute type="xs:string" name="on-edit-load-action" use="optional"/>
        <xs:attribute type="xs:string" name="on-valid" use="optional"/>
        <xs:attribute type="xs:string" name="on-select" use="optional"/>
        <xs:attribute type="xs:string" name="on-row-dblclick" use="optional"/>
