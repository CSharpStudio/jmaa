        <xs:attribute type="xs:string" name="click" use="optional"/>
        <xs:attribute type="xs:string" name="target" use="optional"/>
    </xs:complexType>
    <xs:complexType name="mobileMenuType">
        <xs:sequence>
            <xs:element type="mobileMenuType" name="m-menu" maxOccurs="unbounded" minOccurs="0"/>
        </xs:sequence>
        <xs:attribute type="xs:string" name="id" use="optional"/>
        <xs:attribute type="xs:string" name="seq" use="optional"/>
