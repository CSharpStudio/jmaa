                <script src="/web/org/jmaa/web/statics/plugins/jquery/jquery.min.js?etag=3.6.0"></script>
                <script src="/web/org/jmaa/web/statics/plugins/bootstrap/js/bootstrap.bundle.min.js?etag=4.6.0"></script>
                <script src="/web/org/jmaa/web/statics/plugins/bootstrap-submenu/bootstrap-submenu.min.js?etag=1.0"></script>
                <script
                    src="/web/org/jmaa/web/statics/plugins/overlayScrollbars/js/jquery.overlayScrollbars.min.js?etag=1.13.0"></script>
                <script src="/web/org/jmaa/web/statics/plugins/ChinesePY.js?etag=1.0"></script>
                <script src="/web/org/jmaa/web/statics/plugins/fly.js?etag=1.0"></script>
                <script src="/web/org/jmaa/web/statics/plugins/adminlte/js/adminlte.min.js?etag=3.2.0"></script>

                <script debug="false" src="/web/org/jmaa/web/statics/assets/jmaa.min.js"></script>
                <script debug="false" src="/web/org/jmaa/web/statics/assets/pad/app.min.js"></script>
                <script debug="true" src="/web/org/jmaa/web/statics/jmaa.js"></script>
                <script debug="true" type="module" src="/web/org/jmaa/web/statics/pad/app.js"></script>
            </body>
        </html>
    </web>
