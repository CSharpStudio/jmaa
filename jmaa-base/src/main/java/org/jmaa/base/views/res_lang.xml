<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE data SYSTEM "https://gitee.com/bacheloreric/jmaa/raw/master/files/views.xsd">
<data>
    <view id='view_res_lang_search' name='语言-查询' model='res.lang'>
        <search>
            <field name="name"/>
            <field name="code"/>
            <field name="iso_code"/>
        </search>
    </view>
    <view id='view_res_lang_grid' name='语言-表格' model='res.lang'>
        <grid>
            <toolbar buttons="default">
            </toolbar>
            <field name="name"/>
            <field name="code"/>
            <field name="iso_code"/>
            <field name="active"/>
        </grid>
    </view>
    <view id='view_res_lang_form' name='语言-表单' model='res.lang'>
        <form>
            <toolbar buttons="default">
            </toolbar>
            <field name="name"/>
            <field name="code"/>
            <field name="iso_code"/>
            <field name="active"/>
        </form>
    </view>
    <view id='view_res_localization_resource' name='多语言-资源' model='res.localization'>
        <resource>
            <script src="/web/org/jmaa/base/statics/js/res_lang.js"></script>
        </resource>
    </view>
    <view id='view_res_localization_search' name='多语言-查询' model='res.localization'>
        <search>
            <field name="name"/>
            <field name="value"/>
            <field name="lang_id"/>
        </search>
    </view>
    <view id='view_res_localization_grid' name='多语言-表格' model='res.localization'>
        <grid>
            <toolbar buttons="default">
                <button auth="read" type="button" label="语言" t-click="openLang"/>
            </toolbar>
            <field name="name"/>
            <field name="value"/>
            <field name="lang_id"/>
        </grid>
    </view>
    <view id='view_res_localization_form' name='多语言-表单' model='res.localization'>
        <form>
            <toolbar buttons="default">
            </toolbar>
            <field name="name"/>
            <field name="value"/>
            <field name="lang_id"/>
        </form>
    </view>
</data>
