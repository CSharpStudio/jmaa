<?xml version="1.0" encoding="utf-8"?>
<data noupdate="1">
    <!--计划任务编码规则-->
    <record id="rule_as_plan_task_code" model="code.coding">
        <field name="code">as.plan_task</field>
        <field name="name">计划任务编码规则</field>
        <field name="rule">code.rule</field>
        <field name="source">system</field>
        <field name="active">true</field>
    </record>
    <record id="rule_as_plan_task_code_part1" model="code.part">
        <field name="coding_id" ref="rule_as_plan_task_code"></field>
        <field name="seq">1</field>
        <field name="content">{"code":"T"}</field>
        <field name="part_code">code.part.chars_code</field>
    </record>
    <record id="rule_as_plan_task_code_part2" model="code.part">
        <field name="coding_id" ref="rule_as_plan_task_code"></field>
        <field name="seq">2</field>
        <field name="content"></field>
        <field name="code">${org_code}</field>
        <field name="name">组织代码</field>
    </record>
    <record id="rule_as_plan_task_code_part3" model="code.part">
        <field name="coding_id" ref="rule_as_plan_task_code"></field>
        <field name="seq">3</field>
        <field name="content">{"format_code":"yyMMdd"}</field>
        <field name="part_code">code.part.date_template</field>
    </record>
    <record id="rule_as_plan_task_code_part4" model="code.part">
        <field name="coding_id" ref="rule_as_plan_task_code"></field>
        <field name="seq">4</field>
        <field name="content">{"length":"4","start":"0","step":"1"}</field>
        <field name="part_code">code.part.day_sequence</field>
    </record>
    <!--制程单号编码规则-->
    <record id="rule_craft_order_code" model="code.coding">
        <field name="code">as.craft_order</field>
        <field name="name">制程单号编码规则</field>
        <field name="rule">code.rule</field>
        <field name="source">system</field>
        <field name="active">true</field>
    </record>
    <record id="rule_craft_order_code_part1" model="code.part">
        <field name="coding_id" ref="rule_craft_order_code"></field>
        <field name="seq">1</field>
        <field name="content">{"code":"CO"}</field>
        <field name="part_code">code.part.chars_code</field>
    </record>
    <record id="rule_craft_order_code_part2" model="code.part">
        <field name="coding_id" ref="rule_craft_order_code"></field>
        <field name="seq">2</field>
        <field name="content"></field>
        <field name="code">${org_code}</field>
        <field name="name">组织代码</field>
    </record>
    <record id="rule_craft_order_code_part3" model="code.part">
        <field name="coding_id" ref="rule_craft_order_code"></field>
        <field name="seq">3</field>
        <field name="content">{"format_code":"yyMMdd"}</field>
        <field name="part_code">code.part.date_template</field>
    </record>
    <record id="rule_craft_order_code_part4" model="code.part">
        <field name="coding_id" ref="rule_craft_order_code"></field>
        <field name="seq">4</field>
        <field name="content">{"length":"4","start":"0","step":"1"}</field>
        <field name="part_code">code.part.day_sequence</field>
    </record>
</data>
