<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE data SYSTEM "https://gitee.com/bacheloreric/jmaa/raw/master/files/views.xsd">
<data>
    <view id='code_matcher_search' name='编码匹配-查询' model='code.matcher'>
        <search>
            <field name='name'/>
            <field name='type'/>
        </search>
    </view>
    <view id='code_matcher_grid' name='编码匹配-表格' model='code.matcher'>
        <grid>
            <toolbar buttons='default'>
                <button name="delete" t-enable="ids:source!='system'"></button>
            </toolbar>
            <field name='name'/>
            <field name='type'/>
            <field name='source'/>
            <field name='active'/>
            <field name='is_create'/>
            <field name='remark'/>
        </grid>
    </view>
    <view id='code_matcher_form' name='编码匹配-表单' model='code.matcher'>
        <form>
            <toolbar buttons='default'>
            </toolbar>
            <field name='name'/>
            <field name='type'/>
            <field name='length'/>
            <field name='expression'/>
            <field name='remark' colspan="2"/>
            <field name='active'/>
            <field name='source' visible="false"/>
            <field name='is_create'/>
        </form>
    </view>
</data>
