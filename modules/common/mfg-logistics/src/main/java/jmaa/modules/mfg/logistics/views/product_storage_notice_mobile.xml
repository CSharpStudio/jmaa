<?xml version="1.0" encoding="utf-8"?>

<data>
    <view id="mfg_product_storage_notice_mobile_resource" name="成品入库通知-移动端-资源" model="mfg.product_storage_notice_mobile">
        <resource>
            <script src="/web/jmaa/modules/mfg/logistics/statics/js/product_storage_notice_mobile.js"/>
            <link rel="stylesheet" href="/web/jmaa/modules/md/enterprise/statics/css/msg_editor.css"/>
            <script src="/web/jmaa/modules/md/enterprise/statics/js/msg_editor.js"/>
        </resource>
    </view>

    <view id="mfg_product_storage_notice_mobile_view" name="成品入库通知-移动端" model="mfg.product_storage_notice_mobile">
        <mobile>
            <div class="ui-page" id="main">
                <div data-role="header">
                    <h2>
                        <t>成品入库通知</t>
                    </h2>
                    <a class="home-link"/>
                    <div widget="scanner">
                        <a class="scan-icon"/>
                        <input class="search-product-input focus" type="text" t-enter="searchOrder"
                               placeholder="单号/物料标签"/>
                        <button type="button" class="clear-input" t-click="resetSearchOrder"/>
                    </div>
                </div>
                <div style="height:calc(100% - 84px)">
                    <list ref="orderList" load-method="loadOrderList" on-item-click="openDetails">
                        <card style="margin-bottom:5px;">
                            <field name='code'/>
                            <field name='$rownum' nolabel="1" render="rownum"/>
                            <field name='related_code' colspan="2"/>
                            <field name='material_id' colspan="2"/>
                            <field name='material_name_spec' colspan="2"/>
                            <field name='plan_qty' label="工单计划数"/>
                            <field name='unit_id' label="单位"/>
                            <field name='warehouse_id' colspan="2"/>
                            <field name='scan_qty'/>
                            <field name='status'/>
                        </card>
                    </list>
                </div>
                <div data-role="footer" class="footer-bar">
                    <div class="toolbar">
                        <button class="ui-button" t-click="createOrder">
                            <t>创建</t>
                        </button>
                    </div>
                </div>
            </div>
            <div class="ui-page" id="details">
                <div data-role="header">
                    <h2>
                        <t>成品入库通知</t>
                    </h2>
                    <a class="back-link" t-click="searchOrder" focus-to=".search-product-input"/>
                </div>
                <div style="height:calc(100% - 40px)">
                    <tabs position="footer" ref="tabs">
                        <tab name="productTab" label="扫码" t-click="loadOrder">
                            <div class="tab-header-scan">
                                <div widget="scanner">
                                    <a class="scan-icon"/>
                                    <input class="label-input" type="text" t-enter="scanCode"
                                           placeholder="请扫描标签条码"/>
                                    <button type="button" class="clear-input"/>
                                </div>
                            </div>
                            <div class="header-bar">
                                <div class="toolbar">
                                    <label for="check-auto">
                                        <t>自动确认</t>
                                    </label>
                                    <input id="check-auto" type="checkbox"/>
                                </div>
                            </div>
                            <div style="height:100%;">
                                <form ref="orderForm" on-load="onOrderFormLoad">
                                    <div class="card-view">
                                        <field name='code' editor="card-item" colspan="2"/>
                                        <field name='related_code' editor="card-item" colspan="2"/>
                                        <field name='material_id' editor="card-item" colspan="2"/>
                                        <field name='material_name_spec' editor="card-item" colspan="2"/>
                                        <field name='warehouse_id' required="0" editor="card-item" colspan="2"/>
                                        <field name='status' editor="card-item" colspan="2"/>
                                        <field name='plan_qty' label="计划数量" editor="card-item"/>
                                        <field name='scan_qty' editor="card-item"/>
                                    </div>
                                    <editor label="扫描结果" name="result" type="msg_editor" colspan="2"/>
                                </form>
                            </div>
                        </tab>
                        <tab label="入库明细" t-click="showDetailsList">
                            <div class="header-bar">
                                <div class="toolbar">
                                    <div>
                                        <fieldset data-role="controlgroup" data-type="horizontal">
                                            <label>
                                                <t>全部</t>
                                                <input name="scope" type="radio" value="all"/>
                                            </label>
                                            <label>
                                                <t>未提交</t>
                                                <input checked="checked" name="scope" type="radio" value="undone"/>
                                            </label>
                                        </fieldset>
                                    </div>
                                    <div class="flex-fill"></div>
                                    <button t-click="submitOrder" type="button" class="btn-primary">
                                        <t>生成入库单</t>
                                    </button>
                                </div>
                            </div>
                            <list ref="detailsList" load-method="loadDetailsList" model="mfg.product_storage_notice_details"
                                  style="height:calc(100% - 40px)">
                                <card>
                                    <field name='sn'/>
                                    <field name='$rownum' nolabel="1" render="rownum"/>
                                    <field name='lot_num' colspan="2"/>
                                    <field name='qty'/>
                                    <field name='unit_id'/>
                                    <field name='material_id'/>
                                    <field name='material_category'/>
                                    <field name='material_name_spec' colspan="2"/>
                                    <field name="warehouse_id" label="入库仓库" colspan="2"/>
                                    <div style="position:absolute;right:20px;bottom:10px">
                                        <button class="ui-btn delete-class" t-click="deleteDetails">
                                            <t>删除</t>
                                        </button>
                                    </div>
                                </card>
                            </list>
                        </tab>
                    </tabs>
                </div>
            </div>
        </mobile>
    </view>
    <view id="mfg_product_storage_notice_mobile_form" name="成品入库通知单-移动端-表单" model="mfg.product_storage_notice_mobile">
        <form cols="1">
            <field name='related_code'/>
            <field name="material_id" readonly="0" view="default"/>
            <field name="warehouse_id" label="入库仓库" required="1"/>
            <field name='plan_qty' colspan="2"/>
            <field name='remark' colspan="2"/>
        </form>
    </view>
</data>
