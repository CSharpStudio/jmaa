<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE data SYSTEM "https://gitee.com/bacheloreric/jmaa/raw/master/files/views.xsd">
<data>
    <view id='purchase_order_resource' name='采购订单-资源' model='purchase.order'>
        <resource>
            <script src="/web/jmaa/modules/md/enterprise/statics/js/order_status.js"></script>
            <script src="/web/jmaa/modules/purchase/statics/js/purchase_order.js"></script>
        </resource>
    </view>
    <view id='purchase_order_search' name='采购订单-查询' model='purchase.order'>
        <search>
            <field name='code'/>
            <field name='material_id' label="物料编码" criteria="[['line_ids.material_id.code', 'like', value]]"
                   editor="char"/>
            <field name='material_name_spec' label="物料名称规格"
                   criteria="[['line_ids.material_id.name_spec', 'like', value]]" editor="char"/>
            <field name='supplier_id'/>
            <field name='type'/>
            <field name='company_id'/>
            <field name='order_date' editor="date-range"/>
            <field name='is_return'/>
            <field name='status'/>
        </search>
    </view>
    <view id='purchase_order_grid' name='采购订单-表格' model='purchase.order'>
        <grid>
            <toolbar buttons='default'>
                <button name="delete" t-enable="ids:status=='draft'"/>
                <button label="提交" t-enable="ids:['draft', 'reject'].includes(status)" auth="commit"
                        t-click="commitOrder" class="btn btn-success"/>
                <button label="审核" name="approve" t-enable="ids:status=='commit'" auth="approve"
                        t-click="approveOrder" class="btn btn-info"/>
                <button label="驳回" ref="approve" t-enable="ids:['commit', 'approve'].includes(status)"
                        auth="reject" t-click="rejectOrder" class="btn btn-danger"/>
                <button label="关闭" auth="close" t-enable="!['draft', 'done'].includes(status)"
                        t-click="closeOrder" class="btn-grey" ref="edit"/>
            </toolbar>
            <field name='code'/>
            <field name='status' column="status_column"/>
            <field name='type'/>
            <field name='supplier_id'/>
            <field name='order_date'/>
            <field name='is_return'/>
            <field name='remark'/>
            <field name='company_id'/>
        </grid>
    </view>
    <view id='purchase_order_card' name='采购订单-卡片' model='purchase.order'>
        <card cols="6">
            <toolbar buttons='default'>
                <button name="delete" t-enable="ids:status[0]=='draft'"/>
                <button label="提交" t-enable="ids:['draft', 'reject'].includes(status[0])" auth="commit"
                        t-click="commitOrder" class="btn btn-success"/>
                <button label="审核" name="approve" t-enable="ids:status[0]=='commit'" auth="approve"
                        t-click="approveOrder" class="btn btn-info"/>
                <button label="驳回" ref="approve" t-enable="ids:['commit', 'approve'].includes(status[0])"
                        auth="reject" t-click="rejectOrder" class="btn btn-danger"/>
                <button label="关闭" auth="close" t-enable="!['draft', 'done'].includes(status[0])"
                        t-click="closeOrder" class="btn-grey" ref="edit"/>
            </toolbar>
            <field name='code'/>
            <field name='status'/>
            <field name='type'/>
            <field name='supplier_id'/>
            <field name='order_date'/>
            <field name='is_return'/>
            <template>
                {@helper statusToCss}
                function(s){
                let css = {draft:'warning',commit:'success',approve:'info',reject:'danger'};
                return css[s] || 'secondary';
                }
                {@/helper}
                <div class="card-body">
                    <div class="ribbon-wrapper">
                        <div class="ribbon bg-${status[0]|statusToCss}">
                            <small>${status[1]}</small>
                        </div>
                    </div>
                    <div class="text-title">${code}</div>
                    <div class="text-title">${supplier_id[1]}</div>
                    <div class="text-content">
                        ${order_date}
                    </div>
                </div>
            </template>
        </card>
    </view>
    <view id='purchase_order_form' name='采购订单-表单' model='purchase.order'>
        <form on-load="onFormLoad">
            <toolbar buttons='default'>
                <button label="提交" t-enable="ids:id AND ['draft', 'reject'].includes(status)" auth="commit"
                        t-click="commitOrder" class="btn btn-success"/>
                <button label="审核" name="approve" t-enable="ids:status=='commit'" auth="approve"
                        t-click="approveOrder" class="btn btn-info"/>
                <button label="驳回" ref="approve" t-enable="ids:['commit', 'approve'].includes(status)"
                        auth="reject" t-click="rejectOrder" class="btn btn-danger"/>
                <button label="关闭" auth="close" t-enable="!['draft', 'done'].includes(status)" t-click="closeOrder"
                        class="btn-grey"
                        ref="save"/>
                <field name='status' editor="statusbar" values="draft,commit,approve,done"/>
            </toolbar>
            <field name='code' class="lg" colspan='2' t-readonly="1" placeholder="自动生成"/>
            <field name='supplier_id' class="lg" colspan='2'/>
            <field name='type'/>
            <field name='order_date' min="moment()" default="moment()"/>
            <field name='remark' colspan='2'/>
            <field name='company_id' t-readonly="1"/>
            <tabs>
                <tab label='订单明细'>
                    <field name='line_ids' colspan='4' nolabel='1' t-filter="lineFilter">
                        <grid ordering="0" on-create="onCreateLine" showRowNum="0" footer="1">
                            <toolbar buttons="default">
                                <button name="create" t-click="createLine"/>
                                <div class="input-group" position="after">
                                    <input id="searchInput" t-enter="searchLine" type="text" class="form-control"
                                           placeholder="按物料编码搜索"/>
                                    <div class="input-suffix">
                                        <button type="button" auth="read" class="btn btn-default btn-lookup"
                                                t-click="searchLine">
                                            <i class="fa fa-search">
                                            </i>
                                        </button>
                                    </div>
                                </div>
                            </toolbar>
                            <field name='line_no' t-readonly="1"/>
                            <field name="status" tags="{new:'warning',receive:'success','_':'secondary'}"/>
                            <field name='material_id'/>
                            <field name='material_name_spec'/>
                            <field name='purchase_qty' class="sum col-info"/>
                            <field name='unit_id'/>
                            <field name='purchase_unit_id'/>
                            <field name='deliver_date'/>
                            <field name='receive_qty' class="sum col-warning"/>
                            <field name='stock_in_qty' class="sum col-success"/>
                            <field name='return_qty' class="sum col-danger"/>
                            <field name='material_category'/>
                            <field name="purchase_unit_accuracy" visible="0"/>
                            <edit>
                                <field name='line_no'/>
                                <field name='material_id' on-change-action="onMaterialChange" view="default"
                                       order="code" t-filter="filterMaterial" creatable="0"
                                       nodata-text="没有数据&lt;br/&gt;请维护供应商物料"/>
                                <field name='material_name_spec'/>
                                <field name='material_category'/>
                                <field name='unit_id'/>
                                <field name='purchase_unit_id'/>
                                <field name="purchase_unit_accuracy" visible="0"/>
                                <field name='purchase_qty' gt="0" editor="accuracy" accuracy="purchase_unit_accuracy"/>
                                <field name='deliver_date' min="moment()"/>
                                <field name='status' visible="0"/>
                            </edit>
                        </grid>
                    </field>
                </tab>
                <tab label='消息' t-visible="id">
                    <field name='message_ids' editor="message" colspan='4' nolabel='1'></field>
                </tab>
            </tabs>
        </form>
    </view>
    <view id='purchase_order_lookup' name='采购订单-下拉' model='purchase.order'>
        <lookup>
            <field name='code'/>
            <field name='status' column="status_column"/>
            <field name='type'/>
            <field name='supplier_id'/>
            <field name='order_date'/>
        </lookup>
    </view>
</data>
