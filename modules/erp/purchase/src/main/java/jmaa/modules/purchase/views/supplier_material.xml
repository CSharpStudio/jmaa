<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE data SYSTEM "https://gitee.com/bacheloreric/jmaa/raw/master/files/views.xsd">
<data>
    <view id='supplier_material_search' name='供应商物料-查询' model='purchase.supplier_material'>
        <search>
            <field name='supplier_id'/>
            <field name='material_id'/>
        </search>
    </view>
    <view id='supplier_material_grid' name='供应商物料-表格' model='purchase.supplier_material'>
        <grid>
            <toolbar buttons='default'>
            </toolbar>
            <field name='supplier_id'/>
            <field name='material_id'/>
            <field name='material_name_spec'/>
            <field name='material_supplier_code'/>
            <field name='material_supplier_name'/>
        </grid>
    </view>
    <view id='supplier_material_form' name='供应商物料-表单' model='purchase.supplier_material'>
        <form>
            <toolbar buttons='default'>
            </toolbar>
            <field name='supplier_id'/>
            <field name='material_id' view="default" on-change-action="onMaterialChange"/>
            <field name='material_name_spec'/>
            <field name='material_supplier_code'/>
            <field name='material_supplier_name'/>
        </form>
    </view>
</data>
