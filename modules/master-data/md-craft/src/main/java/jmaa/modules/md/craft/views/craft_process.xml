<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE data SYSTEM "https://gitee.com/bacheloreric/jmaa/raw/master/files/views.xsd">
<data>
    <view id='md_craft_process_search' name='制程工艺-查询' model='md.craft_process'>
        <search>
            <field name='name'/>
        </search>
    </view>
    <view id='md_craft_process_grid' name='制程工艺-表格' model='md.craft_process'>
        <grid>
            <toolbar buttons='default'></toolbar>
            <field name='name'/>
            <field name='craft_type_id'/>
            <field name='craft_section'/>
            <field name='transfer_time'/>
            <field name='cycle_time'/>
            <field name='active'/>
        </grid>
    </view>
    <view id='md_craft_process_form' name='制程工艺-表单' model='md.craft_process'>
        <form>
            <toolbar buttons='default'></toolbar>
            <field name='name'/>
            <field name='craft_type_id'/>
            <field name='craft_section'/>
            <field name='transfer_time'/>
            <field name='cycle_time'/>
            <field name='active'/>
        </form>
    </view>
    <view id='md_craft_process_lookup' name='制程工艺-下拉' model='md.craft_process'>
        <lookup>
            <field name='name'/>
            <field name='craft_type_id'/>
            <field name='craft_section'/>
        </lookup>
    </view>
</data>
