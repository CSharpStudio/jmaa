<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE data SYSTEM "https://gitee.com/bacheloreric/jmaa/raw/master/files/views.xsd">
<data>
    <view id='md_package_rule_resource' name='包装规则-资源' model='md.packing_rule'>
        <resource>
            <script src="/web/jmaa/modules/md/packing/statics/js/packing_rule.js"></script>
        </resource>
    </view>
    <view id='md_package_rule_search' name='包装规则-查询' model='md.packing_rule'>
        <search>
            <field name='name'/>
            <field name='code'/>
            <field name='active'/>
        </search>
    </view>
    <view id='md_package_rule_grid' name='包装规则-表格' model='md.packing_rule'>
        <grid>
            <toolbar buttons='default|copy'></toolbar>
            <field name='code'/>
            <field name='name'/>
            <field name='description'/>
            <field name='active'/>
        </grid>
    </view>
    <view id='md_package_rule_form' name='包装规则-表单' model='md.packing_rule'>
        <form>
            <toolbar buttons='default|copy'>
            </toolbar>
            <field name='code'/>
            <field name='name'/>
            <field name='description'/>
            <field name='active'/>
            <tabs>
                <tab label='包装层级'>
                    <field name='level_ids' colspan='4' nolabel='1' pager="0" limit="1000">
                        <grid ordering="0" on-create="onCreateLevel">
                            <field name='seq'/>
                            <field name='packing_level'/>
                            <field name='package_qty'/>
                            <field name='coding_id' lookup="[['rule','=','code.rule.packing']]"/>
                            <field name='print_template_id' lookup="[['category','=','package_label']]"/>
                            <field name='is_in'/>
                            <field name='is_out'/>
                        </grid>
                    </field>
                </tab>
            </tabs>
        </form>
    </view>
    <view id='md_package_rule_lookup' name='包装规则-下拉' model='md.packing_rule'>
        <lookup>
            <field name='code'/>
            <field name='name'/>
            <field name='description'/>
        </lookup>
    </view>
    <view id='packing_package_level_lookup' name='包装层级-下拉' model='md.packing_level'>
        <lookup>
            <field name='packing_level'/>
            <field name='package_qty'/>
            <field name='coding_id'/>
            <field name='print_template_id'/>
        </lookup>
    </view>
</data>
