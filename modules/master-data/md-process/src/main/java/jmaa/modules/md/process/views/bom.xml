<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE data SYSTEM "https://gitee.com/bacheloreric/jmaa/raw/master/files/views.xsd">
<data>
    <view id='md_bom_form' inherit_id="md-product.md_bom_form" name='BOM-表单-工序扩展' model='md.bom'>
        <xpath expr="form>tabs" position="inside">
            <tab label="工序物料清单">
                <field name="process_bom_ids" nolabel="1" colspan="4">
                    <grid>
                        <field name="unit_accuracy" visible="0"/>
                        <field name='process_id'/>
                        <field name='material_id' view="default" on-change-action="onMaterialChange"/>
                        <field name='material_name_spec'/>
                        <field name='material_category'/>
                        <field name='qty' editor="accuracy" accuracy="unit_accuracy"/>
                        <field name='unit_id'/>
                        <field name='key_module'/>
                        <field name='is_alternative'/>
                        <field name='main_material_id' view="default" t-visible="is_alternative"/>
                    </grid>
                </field>
            </tab>
        </xpath>
    </view>
</data>
