<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE data SYSTEM "https://gitee.com/bacheloreric/web/raw/master/view.xsd">
<data>
    <view id='mfg_feeding_dialog_form' name='上料-表单' model='mfg.feeding_dialog'>
        <form cols="3">
            <field name='workshop_id' link="0"/>
            <field name='resource_id' t-reset="workshop_id" lookup="[['workshop_id','=',workshop_id]]" link="0"/>
            <field name='station_id' default="view" t-reset="resource_id" link="0" t-filter="filterFeedingStation" on-change-action="onStationChange"/>
            <field name='work_order_id' t-reset="resource_id" link="0" view="default" lookup="[['resource_id','=',resource_id],['status','!=','draft']]"/>
            <field name='process_id' link="0" readonly="1" required="0"/>
            <editor label="物料条码" type="char" name='sn' colspan="3" class="xl"/>
            <editor name='msg' label="提示信息" colspan="3" type="msg_editor"/>
        </form>
    </view>
</data>
