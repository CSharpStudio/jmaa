<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE data SYSTEM "https://gitee.com/bacheloreric/web/raw/master/view.xsd">
<data>
    <view id='mfg_product_route_search' name='产品工艺路线-查询' model='mfg.product_route'>
        <search>
            <field name='material_id' label="产品编码"/>
        </search>
    </view>
    <view id='mfg_product_route_grid' name='产品工艺路线-表格' model='mfg.product_route'>
        <grid>
            <toolbar buttons="default"/>
            <field name='material_id' label="产品编码"/>
            <field name='material_name_spec'/>
            <field name='route_version_id'/>
            <field name='begin_date'/>
            <field name='active'/>
        </grid>
    </view>
    <view id='mfg_product_route_form' name='产品工艺路线-表单' model='mfg.product_route'>
        <form>
            <toolbar buttons="default"/>
            <field name='material_id' label="产品编码" view="default" on-change-action="onMaterialChange"/>
            <field name='material_name_spec'/>
            <field name='product_family_id'/>
            <field name='route_version_id' view="default" lookup="[['route_id.family_id','=', product_family_id]]"/>
            <field name='begin_date'/>
            <field name='active'/>
        </form>
    </view>
</data>
