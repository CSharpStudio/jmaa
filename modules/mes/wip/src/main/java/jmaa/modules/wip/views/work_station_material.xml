<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE data SYSTEM "https://gitee.com/bacheloreric/web/raw/master/view.xsd">
<data>
    <view id='mfg_work_station_material_resource' name='工位库存-资源' model='mfg.work_station_material'>
        <resource>
            <link rel="stylesheet" href="/web/jmaa/modules/md/enterprise/statics/css/msg_editor.css"></link>
            <script src="/web/jmaa/modules/md/enterprise/statics/js/msg_editor.js"/>
            <script src="/web/jmaa/modules/print/statics/js/print.js"></script>
            <script src="/web/jmaa/modules/wip/statics/js/feeding.js"></script>
            <script src="/web/jmaa/modules/wip/statics/js/work_station_material.js"></script>
        </resource>
    </view>
    <view id='mfg_work_station_material_search' name='工位库存-查询' model='mfg.work_station_material'>
        <search>
            <field name='station_id'/>
            <field name='material_id'/>
            <field name='resource_id'/>
            <field name='workshop_id'/>
            <field name='company_id' editor="many2many-tags"/>
        </search>
    </view>
    <view id='mfg_work_station_material_grid' name='工位库存-表格' model='mfg.work_station_material'>
        <grid>
            <toolbar buttons='query|export'>
                <button label="上料" t-click="feeding" class="btn-blue"/>
                <button label="下料" t-click="unload" t-enable="id" class="btn-warning"/>
            </toolbar>
            <field name='station_id'/>
            <field name='material_id'/>
            <field name='material_name_spec'/>
            <field name='material_category'/>
            <field name='qty'/>
            <field name='unit_id'/>
            <field name='lot_num'/>
            <field name='resource_id'/>
            <field name='workshop_id'/>
            <field name='company_id'/>
            <field name='unit_accuracy' visible="0"/>
        </grid>
    </view>
</data>
