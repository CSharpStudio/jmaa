<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE data SYSTEM "https://gitee.com/bacheloreric/web/raw/master/view.xsd">
<data>
    <view id='wms_material_receipt_resource' name='来料管理-资源' model='wms.material_receipt'>
        <resource>
            <link rel="stylesheet" href="/web/jmaa/modules/md/enterprise/statics/css/msg_editor.css"/>
            <script src="/web/jmaa/modules/inventory/statics/js/material_receipt.js"/>
            <script src="/web/jmaa/modules/md/enterprise/statics/js/order_status.js"/>
            <script src="/web/jmaa/modules/label/manager/statics/js/print_editors.js"/>
            <script src="/web/jmaa/modules/md/enterprise/statics/js/msg_editor.js"/>
            <script src="/web/jmaa/modules/print/statics/js/print.js"/>
        </resource>
    </view>
    <view id='wms_material_receipt_search' name='来料管理-查询' model='wms.material_receipt'>
        <search>
            <field name='code'/>
            <field name='material_id' label="物料编码" criteria="[['line_ids.material_id.code', 'like', value]]"
                   editor="char"/>
            <field name='material_name_spec' label="物料名称规格"
                   criteria="[['line_ids.material_id.name_spec', 'like', value]]" editor="char"/>
            <field name='type'/>
            <field name='company_id'/>
            <field name='delivery_note'/>
            <field name='customer_id'/>
            <field name='receive_date' editor="date-range"/>
            <field name='remark'/>
        </search>
    </view>
    <view id='wms_material_receipt_grid' name='来料管理-表格' model='wms.material_receipt'>
        <grid>
            <toolbar buttons="default">
                <button name="delete" t-enable="ids:status=='draft'"/>
                <button label="提交" t-enable="ids:id &amp;&amp; ['draft', 'reject'].includes(status)"
                        auth="commit" t-click="commitOrder" class="btn btn-success"/>
                <button label="审核" name="approve" t-enable="ids:status=='commit'" auth="approve"
                        t-click="approveOrder" class="btn btn-info"/>
                <button label="驳回" ref="approve" t-enable="ids:['commit', 'approve'].includes(status)"
                        auth="reject" t-click="rejectOrder" class="btn btn-danger"/>
                <button label="关闭" auth="close" t-enable="!['draft', 'done'].includes(status)"
                        t-click="closeOrder" class="btn-grey" ref="edit"/>
            </toolbar>
            <field name='code'/>
            <field name='status' column="status_column"/>
            <field name='type'/>
            <field name='delivery_note'/>
            <field name='receipt_status'
                   tags="{new:'warning',receiving:'info',received:'success','returned':'danger','_':'secondary'}"/>
            <field name='warehouse_id'/>
            <field name='supplier_id'/>
            <field name='customer_id'/>
            <field name='receive_date'/>
            <field name='create_uid' label="建单人"/>
            <field name='create_date' label="建单时间"/>
            <field name='remark'/>
            <field name='company_id'/>
        </grid>
    </view>
    <view id='wms_material_receipt_card' name='来料管理-卡片' model='wms.material_receipt'>
        <card cols="6">
            <toolbar buttons="default">
                <button name="delete" t-enable="ids:status[0]=='draft'"></button>
                <button label="提交" t-enable="ids:id &amp;&amp; ['draft', 'reject'].includes(status[0])"
                        auth="commit" t-click="commitOrder" class="btn btn-success"/>
                <button label="审核" name="approve" t-enable="ids:status[0]=='commit'" auth="approve"
                        t-click="approveOrder" class="btn btn-info"/>
                <button label="驳回" ref="approve" t-enable="ids:['commit', 'approve'].includes(status[0])"
                        auth="reject" t-click="rejectOrder" class="btn btn-danger"/>
                <button label="关闭" auth="close" t-enable="!['draft', 'done'].includes(status[0])"
                        t-click="closeOrder" class="btn-grey" ref="edit"/>
            </toolbar>
            <field name='code'/>
            <field name='status'/>
            <field name='type'/>
            <field name='delivery_note'/>
            <field name='receipt_status'/>
            <field name='warehouse_id'/>
            <field name='supplier_id'/>
            <field name='receive_date'/>
            <template>
                {@helper statusToCss}
                function(s){
                let css = {draft:'warning',commit:'success',approve:'info',reject:'danger',
                create:'warning',receiving:'info',received:'success','returned':'danger'};
                return css[s] || 'secondary';
                }
                {@/helper}
                <div class="card-body">
                    <div class="ribbon-wrapper">
                        <div class="ribbon bg-${status[0]|statusToCss}">
                            <small>${status[1]}</small>
                        </div>
                    </div>
                    <div class="text-title">${code}</div>
                    <div class="text-title">${supplier_id|$index,1}</div>
                    <div class="text-content">
                        ${delivery_note}
                        <div class="float-right">
                            ${warehouse_id|$index,1}
                        </div>
                    </div>
                    <div class="text-content">
                        <div class="tags bg-${receipt_status[0]|statusToCss}">
                            ${receipt_status[1]}
                        </div>
                        <div class="float-right">
                            ${receive_date}
                        </div>
                    </div>
                </div>
            </template>
        </card>
    </view>
    <view id='wms_material_receipt_form' name='来料管理-表单' model='wms.material_receipt'>
        <form on-load="onFormLoad">
            <toolbar buttons='default'>
                <button name="save" t-enable="['draft', 'reject'].includes(status)"/>
                <button label="提交" t-enable="ids:id AND ['draft', 'reject'].includes(status)"
                        auth="commit" t-click="commitOrder" class="btn btn-success"/>
                <button label="审核" name="approve" t-enable="ids:status=='commit'" auth="approve"
                        t-click="approveOrder" class="btn btn-info"/>
                <button label="驳回" ref="approve" t-enable="ids:['commit', 'approve'].includes(status)"
                        auth="reject" t-click="rejectOrder" class="btn btn-danger"/>
                <button label="关闭" auth="close" t-enable="!['draft', 'done'].includes(status)"
                        t-click="closeOrder" class="btn-grey" ref="save"/>
                <button label="收货" auth="receipt" t-click="receipt" class="btn-primary"
                        t-enable="status=='approve'"></button>
                <button label="报检" auth="createStockIn" t-enable="status=='approve'" t-click="createStockIn"
                        class="btn-success"></button>
                <field name='status' editor="statusbar" values="draft,commit,approve,done"/>
            </toolbar>
            <field name='code' placeholder="自动生成"/>
            <field name='type' t-readonly="id"/>
            <field name='delivery_note' t-reset="type" t-readonly="type=='wms.asn'"/>
            <field name='supplier_id' required="1"/>
            <field name='customer_id'/>
            <field name='warehouse_id'/>
            <field name='receive_date' min="moment()" defaultValue="moment()"/>
            <field name='receipt_status' t-visible="id" readonly="1"/>
            <field name='company_id' readonly="1"/>
            <field name='remark' colspan="2"/>
            <tabs>
                <tab label='物料明细'>
                    <field name='line_ids' colspan='4' nolabel='1' t-filter="lineFilter">
                        <grid checkSelect="1" footer="1">
                            <toolbar buttons='default' on-init="onToolbarInit">
                                <button name="create" t-click="addReceiptLine"></button>
                                <button name="delete" t-enable="ids:status=='new'"></button>
                                <button name="createPallet" label="打印码盘" t-enable="is_pallet"
                                        class="btn-info label-group" t-click="createPallet"/>
                                <button ref="createPallet" label="取消码盘" t-enable="!is_pallet"
                                        confirm="确认取消码盘及绑定的标签?" class="btn-info label-group"
                                        service="cancelPallet"/>
                                <div class="input-group" position="after">
                                    <div class="e-check">
                                        <input id="showUndone" type="checkbox" class="form-control"/>
                                        <label for="showUndone" title="显示未完成物料">未完成</label>
                                    </div>
                                    <input id="searchInput" t-enter="searchLine" type="text" class="form-control"
                                           placeholder="按物料编码搜索"/>
                                    <div class="input-suffix">
                                        <button type="button" auth="read" class="btn btn-default btn-lookup"
                                                t-click="searchLine">
                                            <i class="fa fa-search">
                                            </i>
                                        </button>
                                    </div>
                                </div>
                            </toolbar>
                            <field name='po_id'/>
                            <field name='po_line_no'/>
                            <field name="status"
                                   tags="{'new':'warning','receiving':'info','received':'success','_':'secondary'}"/>
                            <field name="material_id"/>
                            <field name="material_name_spec"/>
                            <field name="request_qty" class="sum col-info"/>
                            <field name="gift_qty" class="sum col-warning"/>
                            <field name="receive_qty" class="sum col-success"/>
                            <field name="unit_id"/>
                            <field name='warehouse_id'/>
                            <field name="purchase_qty" class="sum"/>
                            <field name="material_category"/>
                            <field name="stock_rule"/>
                            <field name="is_pallet"/>
                            <field name='stock_rule' visible="0"/>
                            <field name='po_line_id' visible="0"/>
                            <field name="unit_accuracy" visible="0"/>
                            <edit>
                                <field name="material_id" on-change-action="onMaterialChange" t-readonly="id"
                                       view="default"/>
                                <field name="material_name_spec"></field>
                                <field name="material_category"></field>
                                <field name="unit_id"></field>
                                <field name="unit_accuracy" visible="0"/>
                                <field name='request_qty' gt="0" editor="accuracy" accuracy="unit_accuracy"/>
                                <field name='warehouse_id'/>
                            </edit>
                        </grid>
                    </field>
                </tab>
                <tab label="码盘明细">
                    <field name='pallet_ids' colspan='4' nolabel='1'>
                        <grid>
                            <toolbar buttons='export|reload'>
                                <div class="input-group" position="after">
                                    <input id="searchDetailsInput" t-enter="searchDetails" type="text"
                                           class="form-control"
                                           placeholder="物料编码/标签条码"/>
                                    <div class="input-suffix">
                                        <button type="button" auth="read" class="btn btn-default btn-lookup"
                                                t-click="searchDetails">
                                            <i class="fa fa-search">
                                            </i>
                                        </button>
                                    </div>
                                </div>
                                <button t-click="printPallet" auth="print" t-enable="ids" label="打印"></button>
                            </toolbar>
                            <field name='code' label="LPN"/>
                            <field name='material_id'/>
                            <field name='material_name_spec'/>
                            <field name='qty'/>
                            <field name='package_qty'/>
                        </grid>
                    </field>
                </tab>
                <tab label='收料明细'>
                    <field name='details_ids' colspan='4' nolabel='1' t-filter="detailsFilter">
                        <grid checkSelect="1" footer="1">
                            <toolbar buttons="export|reload">
                                <div class="input-group" position="after">
                                    <input id="searchDetailsInput" t-enter="refresh" type="text" class="form-control"
                                           placeholder="物料编码/标签条码"/>
                                    <div class="input-suffix">
                                        <button type="button" auth="read" class="btn btn-default btn-lookup"
                                                t-click="refresh">
                                            <i class="fa fa-search">
                                            </i>
                                        </button>
                                    </div>
                                </div>
                                <button t-click="reprint" auth="reprint" t-enable="ids" label="补打"></button>
                            </toolbar>
                            <field name='status'
                                   tags="{receive:'info','to-inspect':'warning','to-stock':'success','done':'secondary'}"/>
                            <field name='lot_num'/>
                            <field name='sn'/>
                            <field name='material_id'/>
                            <field name='material_name_spec'/>
                            <field name='qty' class="sum col-success"/>
                            <field name='unit_id'/>
                            <field name='lpn'/>
                            <!--<field name='product_date'/>
                            <field name='product_lot'/>-->
                            <field name='warehouse_id'/>
                            <field name='create_uid'/>
                            <field name='create_date'/>
                        </grid>
                    </field>
                </tab>
                <tab label="检验单">
                    <field name="iqc_sheet_ids" nolabel="1" colspan='4'>
                        <grid>
                            <field name='code'/>
                            <field name='status'
                                   tags="{exempted:'success','to-inspect':'warning','inspecting':'primary',_:'secondary'}"/>
                            <field name='material_id'/>
                            <field name='material_name_spec'/>
                            <field name='material_category'/>
                            <field name='qty'/>
                            <field name='unit_id'/>
                            <field name='result' tags="{ok:'success','ng':'danger'}"/>
                        </grid>
                    </field>
                </tab>
                <tab label='消息' t-visible="id">
                    <field name='message_ids' editor="message" colspan='4' nolabel='1'></field>
                </tab>
            </tabs>
        </form>
    </view>
    <view id='wms_material_receipt_dialog' name='来料接收-对话框' model='wms.material_receipt_dialog'>
        <form logAccess="0" cols="3">
            <editor name="unit_accuracy" type="integer" visible="0"/>
            <field name='material_id' link="0"/>
            <field name='material_name_spec' colspan="2"/>
            <field name='request_qty' editor="accuracy" accuracy="unit_accuracy"/>
            <field name='deficit_qty' editor="accuracy" accuracy="unit_accuracy"/>
            <field name='unit_id'/>
            <field name='print_tpl_id' link="0" lookup="[['category','=','material_label']]"/>
            <field name='min_packages' min="0" readonly="false" t-change="onMinPackagesChange" editor="accuracy"
                   accuracy="unit_accuracy"/>
            <field name='stock_rule'/>
            <field name='commit_qty' min="0" t-change="onCommitQtyChange" editor="accuracy" accuracy="unit_accuracy"/>
            <field name='gift_qty' min="0" t-change="onCommitQtyChange" editor="accuracy" accuracy="unit_accuracy"/>
            <field name='label_count' readonly="1"/>
            <field name='warehouse_id' readonly="1"/>
            <field name='product_date'/>
            <field name='product_lot'/>
            <field name='lot_attr' t-visible="stock_rule!='num'"/>
            <field name='lpn' nolabel="1" editor="label-editor" t-visible="stock_rule!='num'"/>
            <div style="grid-column:span 3;grid-row:span 1" class="form-group col-12">
                <div class="pt-3 d-flex justify-content-between">
                    <button type="button" role="next" class="btn btn-flat btn-lg btn-default">下一个</button>
                    <div>
                        <button type="button" role="reset" class="btn btn-flat btn-lg btn-default mr-3">重置
                        </button>
                        <button type="button" role="print" class="btn btn-flat btn-lg btn-success">打印</button>
                    </div>
                </div>
            </div>
        </form>
    </view>
    <view id='purchase_order_line_dialog' key="purchase_order_line_dialog_key" name='来料接收-选择采购单明细'
          model='purchase.order_line'>
        <grid checkSelect="1" ordering="0" on-load="poLineOnLoad">
            <field name='po_id'/>
            <field name='line_no'/>
            <field name='material_id'/>
            <field name='material_name_spec'/>
            <column name='commit_qty' label="预收数量" type="commit_qty_column" style="color: blue"/>
            <field name='warehouse_id' column="warehouse_column"/>
            <field name='uncommit_qty'/>
            <field name='purchase_qty'/>
            <field name='unit_id'/>
            <field name="material_category"/>
            <field name="stock_rule"/>
            <field name="unit_accuracy" visible="0"/>
        </grid>
    </view>
    <view id='wms_pallet_print_dialog' name='码盘打印对话框' model='wms.pallet_print_dialog'>
        <form cols="1">
            <field name='material_id' visible="0"/>
            <field name='qty' readonly="1"/>
            <field name='packing_level_id' link="0" view="default" editor="packing-editor"
                   on-change-action="onPackingLevelChange"/>
            <field name='package_qty'/>
            <field name='template_id' lookup="[['category','=','package_label']]"/>
        </form>
    </view>
</data>
