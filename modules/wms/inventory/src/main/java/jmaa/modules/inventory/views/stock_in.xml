<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE data SYSTEM "https://gitee.com/bacheloreric/web/raw/master/view.xsd">
<data>
    <view id='stock_stock_in_resource' name='入库单-资源' model='stock.stock_in'>
        <resource>
            <script src="/web/jmaa/modules/inventory/statics/js/stock_in.js"/>
            <script src="/web/jmaa/modules/md/enterprise/statics/js/msg_editor.js"/>
            <script src="/web/jmaa/modules/print/statics/js/print.js"/>
            <link rel="stylesheet" href="/web/jmaa/modules/md/enterprise/statics/css/msg_editor.css"/>
        </resource>
    </view>
    <view id='stock_stock_in_search' name='入库单-查询' model='stock.stock_in'>
        <search>
            <field name='code'/>
            <field name='material_id' label="物料编码" criteria="[['details_ids.material_id.code', 'like', value]]"
                   editor="char"/>
            <field name='material_name_spec' label="物料名称规格"
                   criteria="[['details_ids.material_id.name_spec', 'like', value]]" editor="char"/>
            <field name='status'/>
            <field name='type'/>
            <field name='related_code'/>
            <field name='company_id'/>
        </search>
    </view>
    <view id='stock_stock_in_grid' name='入库单-表格' model='stock.stock_in'>
        <grid>
            <toolbar buttons='query|edit|export'/>
            <field name='code'/>
            <field name='status' tags="{'new':'warning','stocking':'info','done':'success', '_':'secondary'}"/>
            <field name='type'/>
            <field name='related_code' column="ref-link" id-field="related_id" model-field="related_model"/>
            <field name='company_id'/>
            <field name='create_date'/>
            <field name='remark'/>
            <field name='related_model' visible="0"/>
            <field name='related_id' visible="0"/>
        </grid>
    </view>
    <view id='stock_stock_in_form' name='入库单-表单' model='stock.stock_in'>
        <form>
            <toolbar buttons='reload'>
                <button label="入库" t-click="stockIn" class="btn-info"/>
                <field name='status' editor="statusbar" values="new,stocking,done"/>
            </toolbar>
            <field name='code' placeholder="自动生成" readonly="1"/>
            <field name='type' t-readonly="id"/>
            <field name='related_code' t-readonly="id"/>
            <field name='company_id' t-readonly="id"/>
            <tabs>
                <tab label='入库明细'>
                    <field name='details_ids' colspan='4' nolabel='1' t-filter="detailsFilter">
                        <grid checkSelect="1">
                            <toolbar buttons='reload|export' on-init="onToolbarInit">
                                <select class="form-control" id="statusSelect" position="after">
                                    <option value="all">全部</option>
                                    <option value="to-stock">待入库</option>
                                </select>
                                <div class="input-group" position="after">
                                    <input id="searchDetailsInput" t-enter="refresh" type="text" class="form-control"
                                           placeholder="物料/标签/批次"/>
                                    <div class="input-suffix">
                                        <button type="button" auth="read" class="btn btn-default btn-lookup"
                                                t-click="refresh">
                                            <i class="fa fa-search">
                                            </i>
                                        </button>
                                    </div>
                                </div>
                            </toolbar>
                            <field name='status'
                                   tags="{'to-inspect':'secondary','inspect-ng':'secondary','mrb':'secondary','pick_out':'secondary','to-stock':'warning',done:'success','return':'danger'}"/>
                            <field name='lot_num'/>
                            <field name='sn'/>
                            <field name='material_id'/>
                            <field name='material_name_spec'/>
                            <field name='qty' class="col-info"/>
                            <field name='return_qty' class="col-warning"/>
                            <field name='should_stock_qty' class="col-info"/>
                            <field name='stock_qty' class="col-success"/>
                            <field name='wait_stock_qty' class="col-olive"/>
                            <field name='product_date'/>
                            <field name='unit_id'/>
                            <field name='warehouse_id'/>
                            <field name='location_id'/>
                        </grid>
                    </field>
                </tab>
            </tabs>
        </form>
    </view>
    <view id='stock_stock_in_dialog' name='入库单-对话框' model='stock.stock_in_dialog'>
        <form logAccess="0" cols="3">
            <editor name="unit_accuracy" visible="0" type="integer"/>
            <editor label="条码" name='sn' type="char" colspan="2" placeholder="请扫描标签" class="lg"/>
            <editor label="扫描结果" name='result' rowspan="2" type="msg_editor"/>
            <field name='material_id' link="0"/>
            <field name='stock_rule'/>
            <editor label="名称规格" name="material_name_spec" type="char" colspan="2" readonly="1"/>
            <editor label="单位" name="unit_id" type="many2one" readonly="1"/>
            <editor label="应入库数量" name="should_qty" readonly="1" type="accuracy" accuracy="unit_accuracy"/>
            <editor label="已入库数量" name="stock_qty" readonly="1" type="accuracy" accuracy="unit_accuracy"/>
            <editor label="待入库数量" name="left_qty" readonly="1" type="accuracy" accuracy="unit_accuracy"/>
            <field name="warehouse_id" label="入库仓库"/>
            <editor name="suggest_location" label="推荐库位" type="char" readonly="1"/>
            <field name="auto_confirm"/>
            <field name="location_id" label="仓库库位" lookup="[['warehouse_id','=',warehouse_id]]"/>
            <editor name="lock_qty" type="boolean" visible="0"/>
            <editor label="确认数量" name="confirm_qty" t-readonly="lock_qty" gt="0" type="accuracy"
                    accuracy="unit_accuracy" required="1"/>
            <div>
                <button type="button" class="btn btn-lg btn-success stock-material">
                    <t>确认</t>
                </button>
            </div>
        </form>
    </view>
</data>
