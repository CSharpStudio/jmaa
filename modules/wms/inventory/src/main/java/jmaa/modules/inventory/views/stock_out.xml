<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE data SYSTEM "https://gitee.com/bacheloreric/web/raw/master/view.xsd">
<data>
    <view id='stock_stock_out_resource' name='出库单-资源' model='stock.stock_out'>
        <resource>
            <script src="/web/jmaa/modules/inventory/statics/js/stock_out.js"/>
        </resource>
    </view>
    <view id='stock_stock_out_search' name='出库单-查询' model='stock.stock_out'>
        <search>
            <field name='code'/>
            <field name='material_id' label="物料编码" criteria="[['details_ids.material_id.code', 'like', value]]"
                   editor="char"/>
            <field name='material_name_spec' label="物料名称规格"
                   criteria="[['details_ids.material_id.name_spec', 'like', value]]" editor="char"/>
            <field name='status'/>
            <field name='type'/>
            <field name='related_code'/>
            <field name='company_id'/>
        </search>
    </view>
    <view id='stock_stock_out_grid' name='出库单-表格' model='stock.stock_out'>
        <grid>
            <toolbar buttons='query|edit|export'></toolbar>
            <field name='code'/>
            <field name='status' tags="{'create':'warning','stocking':'info','_':'success'}"/>
            <field name='type'/>
            <field name='related_code' column="ref-link" id-field="related_id" model-field="related_model"/>
            <field name='company_id'/>
            <field name='create_date'/>
            <field name='remark'/>
            <field name='related_model' visible="0"/>
            <field name='related_id' visible="0"/>
        </grid>
    </view>
    <view id='stock_stock_out_form' name='出库单-表单' model='stock.stock_out'>
        <form>
            <toolbar buttons='reload'>
                <field name='status' editor="statusbar" values="new,stocking,done"/>
            </toolbar>
            <field name='code' placeholder="自动生成" readonly="1"/>
            <field name='type' t-readonly="id"/>
            <field name='related_code' t-readonly="id"/>
            <field name='company_id' t-readonly="id"/>
            <tabs>
                <tab label='出库明细'>
                    <field name='details_ids' colspan='4' nolabel='1' t-filter="detailsFilter">
                        <grid>
                            <toolbar buttons='export|reload'>
                                <div class="input-group" position="after">
                                    <input id="searchDetailsInput" t-enter="refresh" type="text" class="form-control"
                                           placeholder="物料/标签/批次"/>
                                    <div class="input-suffix">
                                        <button type="button" auth="read" class="btn btn-default btn-lookup"
                                                t-click="refresh">
                                            <i class="fa fa-search">
                                            </i>
                                        </button>
                                    </div>
                                </div>
                            </toolbar>
                            <field name="status" tags="{'new':'warning','done':'success'}"/>
                            <field name='sn'/>
                            <field name='lot_num'/>
                            <field name='material_id'/>
                            <field name='material_name_spec'/>
                            <field name='qty'/>
                            <field name='unit_id'/>
                            <field name='warehouse_id'/>
                            <field name='location_id'/>
                            <field name='update_uid'/>
                            <field name='update_date'/>
                        </grid>
                    </field>
                </tab>
            </tabs>
        </form>
    </view>
</data>
